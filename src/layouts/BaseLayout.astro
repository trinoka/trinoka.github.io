---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import constants from '../data/constants.json' assert { type: 'json' };

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
}

const { title, description, canonical, ogImage, ogType = 'website' } = Astro.props;
const siteTitle = `${title} | ${constants.legalName}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={constants.favicon} />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <meta name="application-name" content={constants.legalName} />
    <meta name="apple-mobile-web-app-title" content={constants.legalName} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content={constants.theme.iosStatusBarStyle} />
    <meta name="msapplication-TileColor" content={constants.theme.defaultColor} />
    <meta name="theme-color" content={constants.theme.defaultColor} />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content={constants.theme.lightColor} />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content={constants.theme.darkColor} />
    <meta name="color-scheme" content="light dark" />

    <script is:inline define:vars={{ lightThemeColor: constants.theme.lightColor, darkThemeColor: constants.theme.darkColor }}>
      const root = document.documentElement;
      const themeStorageKey = 'trinoka-theme';
      const dynamicThemeMeta = document.querySelector('meta[name="theme-color"]:not([media])');
      const prefersDarkMode = window.matchMedia?.('(prefers-color-scheme: dark)');

      const resolveMode = (theme) => {
        if (theme === 'dark') return 'dark';
        if (theme === 'light') return 'light';
        return prefersDarkMode?.matches ? 'dark' : 'light';
      };

      const applyTheme = (theme) => {
        const normalizedTheme = theme === 'dark' || theme === 'light' ? theme : 'auto';
        const resolvedMode = resolveMode(normalizedTheme);

        root.dataset.theme = normalizedTheme;
        root.dataset.mode = resolvedMode;

        if (dynamicThemeMeta) {
          dynamicThemeMeta.setAttribute('content', resolvedMode === 'dark' ? darkThemeColor : lightThemeColor);
        }

        window.dispatchEvent(
          new CustomEvent('themechange', {
            detail: { theme: normalizedTheme, mode: resolvedMode }
          })
        );
      };

      let storedTheme = 'auto';
      try {
        storedTheme = localStorage.getItem(themeStorageKey) || 'auto';
      } catch {
        storedTheme = 'auto';
      }

      applyTheme(storedTheme);

      const handleSystemThemeChange = () => {
        if ((root.dataset.theme || 'auto') === 'auto') {
          applyTheme('auto');
        }
      };

      if (prefersDarkMode) {
        if (typeof prefersDarkMode.addEventListener === 'function') {
          prefersDarkMode.addEventListener('change', handleSystemThemeChange);
        } else if (typeof prefersDarkMode.addListener === 'function') {
          prefersDarkMode.addListener(handleSystemThemeChange);
        }
      }

      window.__trinokaTheme = {
        getTheme: () => root.dataset.theme || 'auto',
        getMode: () => root.dataset.mode || resolveMode('auto'),
        setTheme: (theme) => {
          const normalizedTheme = theme === 'dark' || theme === 'light' ? theme : 'auto';

          try {
            if (normalizedTheme === 'auto') {
              localStorage.removeItem(themeStorageKey);
            } else {
              localStorage.setItem(themeStorageKey, normalizedTheme);
            }
          } catch {
            // Ignore storage access failures and still apply in-memory theme.
          }

          applyTheme(normalizedTheme);
        }
      };
    </script>
    
    <SEO 
      title={siteTitle}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
    />

    <!-- Prevent indexing when disabled in constants -->
    { !constants.indexingAllowed && (
      <meta name="robots" content="noindex, nofollow" />
    ) }
    
    <!-- Preconnect to Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    
    <Header />
    
    <main id="main-content" class="flex-grow">
      <slot />
    </main>
    
    <Footer />
    
    <!-- Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": constants.legalName,
      "legalName": constants.legalName,
      "url": constants.siteUrl,
      "logo": `${constants.siteUrl}${constants.logo}`,
      "description": "Trinoka LLP is a Limited Liability Partnership incorporated under the LLP Act, 2008, operating across mobility, hospitality, technology, and consulting domains.",
      "foundingDate": constants.foundingDate,
      "address": {
        "@type": "PostalAddress",
        "streetAddress": constants.registeredOffice.streetAddress,
        "addressLocality": constants.registeredOffice.locality,
        "postalCode": constants.registeredOffice.postalCode,
        "addressRegion": constants.registeredOffice.region,
        "addressCountry": constants.registeredOffice.country
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "email": constants.email,
        "contactType": "General Inquiry"
      },
      "sameAs": []
    })} />
  </body>
</html>
